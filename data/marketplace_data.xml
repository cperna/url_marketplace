<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Fusionar y limpiar duplicados cada vez que se actualice el módulo -->
        <function model="marketplace.marketplace" name="_clean_duplicate_marketplaces"/>
        
        <!-- Acción de servidor para auto-corregir enlaces desde la vista de lista de productos -->
        <record id="action_auto_correct_marketplaces" model="ir.actions.server">
            <field name="name">Auto-Corregir URLs de Marketplaces</field>
            <field name="model_id" ref="product.model_product_template"/>
            <field name="binding_model_id" ref="product.model_product_template"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">
                if records:
                    records.action_auto_correct_marketplaces()
            </field>
        </record>
    </data>
</odoo>
