<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_marketplace" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.marketplace</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="90"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Marketplaces" string="Marketplaces" name="url_marketplace" groups="base.group_system">
                    <block title="Falabella Seller Center API" name="falabella_api_setting_container">
                        <setting id="falabella_api_setting" string="Falabella API Credentials" help="Configura las credenciales para sincronizar precios automáticamente.">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="falabella_api_user_id" class="col-lg-3 o_light_label"/>
                                    <field name="falabella_api_user_id" class="oe_inline"/>
                                </div>
                                <div class="row">
                                    <label for="falabella_api_key" class="col-lg-3 o_light_label"/>
                                    <field name="falabella_api_key" class="oe_inline" password="True"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                    
                    <block title="Ripley Seller Center API (Mirakl)" name="ripley_api_setting_container">
                        <setting id="ripley_api_setting" string="Ripley API Credentials" help="Configura la clave API de Mirakl para sincronizar stock y precios de Ripley.">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="ripley_api_key" class="col-lg-3 o_light_label"/>
                                    <field name="ripley_api_key" class="oe_inline" password="True"/>
                                </div>
                                <div class="row">
                                    <label for="ripley_shop_id" class="col-lg-3 o_light_label"/>
                                    <field name="ripley_shop_id" class="oe_inline"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                    
                    <block title="Mercado Libre API" name="ml_api_setting_container">
                        <setting id="ml_api_setting" string="Mercado Libre API Credentials" help="Credenciales OAuth 2.0 de la aplicación en developers.mercadolibre.com">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="ml_app_id" class="col-lg-3 o_light_label"/>
                                    <field name="ml_app_id" class="oe_inline"/>
                                </div>
                                <div class="row mt8">
                                    <label for="ml_secret_key" class="col-lg-3 o_light_label"/>
                                    <field name="ml_secret_key" class="oe_inline" password="True"/>
                                </div>
                                <div class="row mt8">
                                    <label for="ml_redirect_uri" class="col-lg-3 o_light_label"/>
                                    <field name="ml_redirect_uri" class="oe_inline" placeholder="https://tusitio.com"/>
                                </div>
                                <div class="row mt8">
                                    <label for="ml_auth_code" class="col-lg-3 o_light_label" string="Código TG"/>
                                    <field name="ml_auth_code" class="oe_inline" password="True" placeholder="TG-648b263..."/>
                                </div>
                                <div class="text-muted mt16">
                                    <p>Guarde la configuración y la próxima vez que se ejecute la sincronización de precios Odoo convertirá el código TG en un Token de acceso permanente.</p>
                                </div>
                            </div>
                        </setting>
                    </block>
                    
                    <block title="VTEX API (Claro Perú)" name="vtex_api_setting_container">
                        <setting id="vtex_api_setting" string="VTEX API Credentials" help="Credenciales de AppKey y AppToken generadas en VTEX">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="vtex_account_name" class="col-lg-3 o_light_label"/>
                                    <field name="vtex_account_name" class="oe_inline" placeholder="ej. claroperu"/>
                                </div>
                                <div class="row mt8">
                                    <label for="vtex_app_key" class="col-lg-3 o_light_label"/>
                                    <field name="vtex_app_key" class="oe_inline"/>
                                </div>
                                <div class="row mt8">
                                    <label for="vtex_app_token" class="col-lg-3 o_light_label"/>
                                    <field name="vtex_app_token" class="oe_inline" password="True"/>
                                </div>
                                <div class="row mt8">
                                    <label for="vtex_marketplace_id" class="col-lg-3 o_light_label"/>
                                    <field name="vtex_marketplace_id" class="oe_inline"/>
                                </div>
                                <div class="mt16">
                                    <button name="action_import_vtex_catalog" type="object" string="Importar Catálogo de VTEX" class="btn-primary" icon="fa-cloud-download"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <!-- Acción para acceder directamente si lo deseas -->
    <record id="action_marketplace_config_settings" model="ir.actions.act_window">
        <field name="name">Ajustes de Marketplaces</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module' : 'url_marketplace', 'bin_size': False}</field>
    </record>
</odoo>
